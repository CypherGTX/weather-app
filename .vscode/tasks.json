{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vite Dev (WSL)",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
	  "options": {
        "cwd": "${fileDirname}"
	  },
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*ready in.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}